{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and statistics",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "matches": { "type": "number" },
        "wins": { "type": "number" },
        "losses": { "type": "number" },
        "achievements": { "type": "array", "items": { "type": "string" } },
        "lastLogin": { "type": "string", "format": "date-time" }
      }
    },
    "DailyStreak": {
      "title": "DailyStreak",
      "description": "Information about consecutive days logged in",
      "type": "object",
      "properties": {
        "currentStreak": { "type": "number" },
        "lastLoginDate": { "type": "string" },
        "lastClaimedDate": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profile data."
    },
    "/users/{userId}/dailyStreak/info": {
      "schema": { "$ref": "#/entities/DailyStreak" },
      "description": "Daily streak progress schema."
    }
  }
}
